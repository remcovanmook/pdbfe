{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": true,
    "strictNullChecks": false,
    "allowJs": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": [
    "js/**/*.js",
    "types.d.ts"
  ],
  "exclude": [
    "tests/**",
    "node_modules",
    "third_party/**"
  ]
}
