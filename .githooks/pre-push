#!/bin/bash
#
# Pre-push hook: runs the full test suite including Playwright E2E tests.
# Rejects the push if any check fails.
#
# This is intentionally separate from pre-commit — Playwright requires a
# running wrangler pages dev server and is too slow for every commit.
# Run the full suite here before any push to origin.
#
# Install: git config core.hooksPath .githooks
#

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

fail() {
    echo -e "${RED}✖ $1${NC}"
    exit 1
}

pass() {
    echo -e "${GREEN}✔ $1${NC}"
}

echo "Running pre-push checks (full suite including E2E)..."

# ── Workers ──────────────────────────────────────────────────────────

cd workers

npm run typecheck --silent 2>&1 || fail "workers typecheck failed"
pass "workers typecheck"

npm test --silent 2>&1 || fail "workers tests failed"
pass "workers tests"

npm run test:upstream --silent 2>&1 || fail "upstream pattern tests failed"
pass "upstream pattern tests"

cd ..

# ── XSS Linter ───────────────────────────────────────────────────────

node scripts/lint_xss.js 2>&1 || fail "XSS linting failed"
pass "XSS linting"

# ── Frontend ─────────────────────────────────────────────────────────

cd frontend

npm run typecheck --silent 2>&1 || fail "frontend typecheck failed"
pass "frontend typecheck"

npm run test:unit --silent 2>&1 || fail "frontend unit tests failed"
pass "frontend unit tests"

# Playwright E2E — requires wrangler pages dev running on :8788.
# Start it if not already running, or rely on reuseExistingServer.
npm run test:e2e --silent 2>&1 || fail "frontend E2E tests failed"
pass "frontend E2E tests"

cd ..

echo -e "${GREEN}All pre-push checks passed.${NC}"
exit 0
