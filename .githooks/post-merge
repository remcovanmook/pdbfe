#!/bin/bash
#
# Post-merge hook: runs deploy after merging into main.
#
# Only triggers on merges to main. Applies pending D1 migrations and
# deploys all workers + frontend to production.
#
# Install: git config core.hooksPath .githooks
#

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

if [[ "$BRANCH" != "main" ]]; then
    echo -e "${YELLOW}⚠ Not on main ($BRANCH), skipping deploy.${NC}"
    exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)/scripts"

echo -e "${GREEN}Merged to main — starting deploy...${NC}"
echo ""

"$SCRIPT_DIR/deploy.sh" --remote --apply-migrations

echo ""
echo -e "${GREEN}Deploy complete.${NC}"
