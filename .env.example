# PeeringDB API credentials
export PEERINGDB_API_KEY=<your-peeringdb-api-key>
export PDB_TEST_KEY=<your-test-api-key>

# Cloudflare credentials
export CLOUDFLARE_API_TOKEN=<your-cloudflare-api-token>
export CLOUDFLARE_ACCESS_CLIENT_ID=<your-access-client-id>
export CLOUDFLARE_ACCESS_CLIENT_SECRET=<your-access-client-secret>

# PeeringDB OAuth application (register at https://auth.peeringdb.com)
export OAUTH_PEERINGDB_ID=<your-oauth-app-id>
export OAUTH_PEERINGDB_SECRET=<your-oauth-app-secret>

# pdbfe-issued API key (for internal auth verification)
export BDGNIREEP_API_KEY=pdbfe.<32-hex-chars>

# Deployment hostnames
export WORKERS_DOMAIN=<your-subdomain>.workers.dev
export FRONTEND_HOSTNAME=<your-pages-project>.pages.dev
export AUTH_HOSTNAME=pdbfe-auth.$WORKERS_DOMAIN
export API_HOSTNAME=pdbfe-api.$WORKERS_DOMAIN
