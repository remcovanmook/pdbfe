name = "pdbfe-sync"
main = "sync/index.js"
compatibility_date = "2026-03-18"

[[d1_databases]]
binding = "PDB"
database_name = "peeringdb"
database_id = "<your-d1-database-id>"

[triggers]
crons = ["*/15 * * * *"]

# Production: set PDB_API_KEY via `wrangler secret put PEERINGDB_API_KEY --config wrangler-sync.toml`
# Local dev: uncomment below
# [vars]
# PEERINGDB_API_KEY = ""

[vars]
PDBFE_VERSION = "<your-version>"

[[r2_buckets]]
binding = "LOGOS"
bucket_name = "pdbfe-logos"

# Workers AI — required for vector embedding (syncVectors).
# Without this binding, the sync worker skips vector embedding entirely.
[ai]
binding = "AI"

# Vectorize index — required for vector embedding.
# Create with: wrangler vectorize create pdbfe-vectors --dimensions=1024 --metric=cosine
[[vectorize]]
binding = "VECTORIZE"
index_name = "pdbfe-vectors"
