# Template for pdbfe-sync worker. Copy to wrangler-sync.toml and fill in IDs.
# Generated automatically by: ./scripts/deploy.sh --generate-configs
name = "pdbfe-sync"
main = "sync/index.js"
compatibility_date = "2026-03-18"

[triggers]
crons = ["*/15 * * * *"]

[[d1_databases]]
binding = "PDB"
database_name = "peeringdb"
database_id = "<your-d1-database-id>"

# pdbfe-tasks Queue producer — async tasks (embed, delete, logo) are published
# here and consumed by the pdbfe-async worker.
# Create with: wrangler queues create pdbfe-tasks
[[queues.producers]]
queue   = "pdbfe-tasks"
binding = "QUEUE"

# Production: set via `wrangler secret put PEERINGDB_API_KEY --config wrangler-sync.toml`
# Local dev: add to [vars] temporarily, never commit.
[vars]
PDBFE_VERSION = "<your-version>"
