name = "pdbfe-auth"
main = "auth/index.js"
compatibility_date = "2026-03-18"

[[kv_namespaces]]
binding = "SESSIONS"
id = "<your-sessions-kv-namespace-id>"

[[kv_namespaces]]
binding = "USERS"
id = "<your-users-kv-namespace-id>"

# Production: set secrets via wrangler secret put --config wrangler-auth.toml
#   wrangler secret put OAUTH_CLIENT_ID --config wrangler-auth.toml
#   wrangler secret put OAUTH_CLIENT_SECRET --config wrangler-auth.toml
#
# Local dev: uncomment the [vars] section and set values directly
# [vars]
# OAUTH_CLIENT_ID = ""
# OAUTH_CLIENT_SECRET = ""
# OAUTH_REDIRECT_URI = "http://localhost:8788/auth/callback"
# FRONTEND_ORIGIN = "http://localhost:8080"

[vars]
OAUTH_REDIRECT_URI = "https://pdbfe-auth.<your-subdomain>.workers.dev/auth/callback"
FRONTEND_ORIGIN = "https://<your-pages-project>.pages.dev"
